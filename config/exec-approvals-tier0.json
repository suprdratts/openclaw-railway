{
  "version": 1,
  "agents": {
    "main": {
      "security": "allowlist",
      "ask": "off",
      "askFallback": "deny",
      "autoAllowSkills": false,
      "allowlist": [
        {
          "id": "tier0-ls-usr",
          "pattern": "/usr/bin/ls",
          "lastUsedCommand": "ls"
        },
        {
          "id": "tier0-ls-bin",
          "pattern": "/bin/ls",
          "lastUsedCommand": "ls"
        }
      ]
    }
  }
}
